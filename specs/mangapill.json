{
  "baseUrl": "https://mangapill.com",
  "chapters": {
    "chapterSlugRegex": "/chapters/([^?#]+)",
    "list": {
      "fields": {
        "number": {
          "regex": "Chapter\\s*([0-9.]+)"
        },
        "title": {},
        "url": {
          "attr": "href"
        }
      },
      "rows": "#chapters > div > a"
    },
    "url": "{base}/manga/{slug}"
  },
  "details": {
    "fields": {
      "description": {
        "sel": "div.container > div:first-child > div:last-child > div:nth-child(2) > p"
      },
      "genres": {
        "sel": "a[href*='genre']"
      },
      "status": {
        "map": {
          "Finished": "Completed",
          "Publishing": "Ongoing"
        },
        "sel": "div.container > div:first-child > div:last-child > div:nth-child(3) > div:nth-child(2) > div"
      },
      "thumbnail": {
        "attr": "data-src",
        "sel": "div.container > div:first-child > div:first-child > img"
      },
      "title": {
        "sel": "div.container h1.font-bold"
      }
    },
    "url": "{base}/manga/{slug}"
  },
  "iconUrl": "https://mangapill.com/static/favicon/android-chrome-512x512.png",
  "id": "mangapill",
  "imageHosts": [
    "https://cdn.readdetectiveconan.com/*"
  ],
  "lang": "en",
  "name": "MangaPill",
  "pages": {
    "list": {
      "fields": {
        "url": {
          "attr": "data-src"
        }
      },
      "rows": "picture img"
    },
    "url": "{base}/chapters/{chapterSlug}"
  },
  "referer": "https://mangapill.com/",
  "requestDelayMs": 1000,
  "search": {
    "list": {
      "fields": {
        "thumbnail": {
          "attr": "data-src",
          "sel": "img"
        },
        "title": {
          "sel": "div.line-clamp-2"
        },
        "url": {
          "attr": "href",
          "sel": "a[href^='/manga/']"
        }
      },
      "rows": ".grid > div:not([class])"
    },
    "slugRegex": "/manga/([^?#]+)",
    "url": "{base}/search?page={page}&q={query}"
  },
  "spec": 1
}