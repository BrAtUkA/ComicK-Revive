{
  "baseUrl": "https://weebcentral.com",
  "chapters": {
    "chapterSlugRegex": "/chapters/([^/?#]+)",
    "dateFormat": "iso",
    "list": {
      "fields": {
        "date": {
          "attr": "datetime",
          "sel": "time[datetime]"
        },
        "title": {
          "sel": "span.flex > span"
        },
        "url": {
          "attr": "href"
        }
      },
      "rows": "div[x-data] > a"
    },
    "url": "{base}/series/{slug}/full-chapter-list"
  },
  "details": {
    "fields": {
      "author": {
        "index": 0,
        "sel": "section[x-data] > section",
        "then": {
          "containsText": "Author",
          "sel": "ul > li",
          "then": {
            "sel": "span > a"
          }
        }
      },
      "description": {
        "index": 1,
        "sel": "section[x-data] > section",
        "then": {
          "containsText": "Description",
          "sel": "li",
          "then": {
            "sel": "p"
          }
        }
      },
      "genres": {
        "index": 0,
        "sel": "section[x-data] > section",
        "then": {
          "containsText": "Tag",
          "sel": "ul > li",
          "then": {
            "sel": "a"
          }
        }
      },
      "status": {
        "index": 0,
        "map": {
          "Canceled": "Cancelled",
          "Complete": "Completed",
          "Hiatus": "Hiatus",
          "Ongoing": "Ongoing"
        },
        "sel": "section[x-data] > section",
        "then": {
          "containsText": "Status",
          "sel": "ul > li",
          "then": {
            "sel": "a"
          }
        }
      },
      "thumbnail": {
        "fallback": {
          "index": 0,
          "sel": "section[x-data] > section",
          "then": {
            "attr": "src",
            "sel": "img"
          }
        },
        "index": 0,
        "sel": "section[x-data] > section",
        "then": {
          "attr": "srcset",
          "regex": "^\\S+",
          "replace": [
            [
              "small",
              "normal"
            ]
          ],
          "sel": "source"
        }
      },
      "title": {
        "index": 1,
        "sel": "section[x-data] > section",
        "then": {
          "sel": "h1"
        }
      }
    },
    "url": "{base}/series/{slug}"
  },
  "iconUrl": "https://weebcentral.com/static/images/brand.png",
  "id": "weebcentral",
  "imageHosts": [
    "https://*/*"
  ],
  "lang": "en",
  "name": "WeebCentral",
  "pages": {
    "list": {
      "fields": {
        "url": {
          "attr": "src"
        }
      },
      "rows": "section[x-data*=scroll] > img"
    },
    "url": "{base}/chapters/{chapterSlug}/images?is_prev=False&reading_style=long_strip"
  },
  "referer": "https://weebcentral.com/",
  "requestDelayMs": 2000,
  "search": {
    "list": {
      "fields": {
        "thumbnail": {
          "attr": "src",
          "sel": "img"
        },
        "title": {
          "sel": "div:not([class])"
        },
        "url": {
          "attr": "href"
        }
      },
      "rows": "article > section > a"
    },
    "pageSize": 32,
    "queryReplace": [
      "[!#:(),\\-]",
      " "
    ],
    "slugRegex": "/series/([^/]+)",
    "url": "{base}/search/data?text={query}&limit=32&offset={offset}&sort=Best+Match&order=Descending&display_mode=Full+Display"
  },
  "spec": 1
}